#!/usr/bin/env python3
"""
Pure Python Aer Simulator - Drop-in replacement for qiskit-aer
Works perfectly on Termux without ANY compilation!
"""
from qiskit import QuantumCircuit
from qiskit.quantum_info import Statevector

class AerSimulator:
    """Pure Python Aer replacement - same API as real Aer"""
    
    def __init__(self, method='statevector'):
        self.method = method
        print("✅ Pure Python Aer Simulator initialized")
    
    def run(self, circuits, shots=1024):
        """Run quantum circuits"""
        if not isinstance(circuits, list):
            circuits = [circuits]
        
        results = []
        for qc in circuits:
            # Remove measurements for statevector
            qc_no_meas = qc.remove_final_measurements(inplace=False)
            
            # Get statevector using Qiskit's built-in (pure Python)
            sv = Statevector.from_instruction(qc_no_meas)
            
            # Sample measurements
            counts = sv.sample_counts(shots=shots)
            results.append(counts)
        
        return AerResult(results)

class AerResult:
    """Result object compatible with Aer API"""
    
    def __init__(self, results):
        self._results = results
    
    def get_counts(self, circuit=0):
        return self._results[circuit]
    
    def result(self):
        return self

# Alias for compatibility
Aer = type('Aer', (), {
    'get_backend': lambda name: AerSimulator()
})()

# Test it
if __name__ == "__main__":
    print("\n🧪 Testing Pure Python Aer Simulator\n")
    
    # Test 1: Bell State
    print("1️⃣ Bell State (2 qubits):")
    qc = QuantumCircuit(2)
    qc.h(0)
    qc.cx(0, 1)
    qc.measure_all()
    
    sim = AerSimulator()
    result = sim.run(qc, shots=1000)
    print(f"   {result.get_counts()}")
    
    # Test 2: GHZ State
    print("\n2️⃣ GHZ State (3 qubits):")
    qc2 = QuantumCircuit(3)
    qc2.h(0)
    qc2.cx(0, 1)
    qc2.cx(0, 2)
    qc2.measure_all()
    
    result2 = sim.run(qc2, shots=1000)
    print(f"   {result2.get_counts()}")
    
    # Test 3: Superposition
    print("\n3️⃣ Superposition (1 qubit):")
    qc3 = QuantumCircuit(1)
    qc3.h(0)
    qc3.measure_all()
    
    result3 = sim.run(qc3, shots=1000)
    print(f"   {result3.get_counts()}")
    
    print("\n✅ Pure Python Aer working perfectly!")
    print("💡 Use this in your quantum scripts - no compilation needed!")
    print("\n📝 Usage:")
    print("   from aer_simulator import AerSimulator")
    print("   sim = AerSimulator()")
    print("   result = sim.run(circuit, shots=1000)")
